version: "3.9"

services:
  postgres:
    image: postgres:14
    container_name: ssequel-postgres-dev
    restart: unless-stopped
    environment:
      POSTGRES_DB: ssequel_dev
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
    ports:
      - "5434:5432"
    volumes:
      - ssequel_postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres -d ssequel_dev"]
      interval: 5s
      timeout: 5s
      retries: 10

  mailhog:
    image: mailhog/mailhog:v1.0.1
    container_name: ssequel-mailhog-dev
    restart: unless-stopped
    ports:
      - "1025:1025"
      - "8025:8025"

volumes:
  ssequel_postgres_data:
