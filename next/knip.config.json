{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "next.config.js",
    "proxy.ts",
    "postcss.config.js",
    "tailwind.config.ts",
    "vitest.config.ts",
    "scripts/**/*.ts",
    "scripts/**/*.mjs",
    "scripts/**/*.cjs",
    "app/**/*.{ts,tsx}",
    "components/**/*.{ts,tsx}",
    "lib/**/*.{ts,tsx,js}",
    "hooks/**/*.{ts,tsx}",
    "contexts/**/*.{ts,tsx}"
  ],
  "project": [
    "app/**/*.{ts,tsx}",
    "components/**/*.{ts,tsx}",
    "lib/**/*.{ts,tsx,js}",
    "hooks/**/*.{ts,tsx}",
    "contexts/**/*.{ts,tsx}",
    "types/**/*.ts",
    "scripts/**/*.{ts,mjs,cjs}",
    "__tests__/**/*.ts"
  ],
  "ignore": [
    ".next/**",
    "coverage/**",
    "node_modules/**",
    "prisma/generated/**"
  ],
  "ignoreBinaries": ["website-the-ssequel"],
  "ignoreDependencies": ["website-the-ssequel"]
}
