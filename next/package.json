{
  "name": "website-the-ssequel",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "^24.0.0 || 25.9.x"
  },
  "scripts": {
    "preinstall": "node ./scripts/check-node-version.cjs",
    "prepare": "husky",
    "env:check": "node ./scripts/validate-env.mjs",
    "dev": "cross-env INTERNAL_API_URL=\"http://localhost:3000\" SESSION_COOKIE_NAME=\"next-auth.session-token\" next dev",
    "dev:safe": "npm run env:check && npm run dev",
    "build": "next build",
    "start": "next start",
    "migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "prisma db seed",
    "prisma:migrate": "prisma migrate dev",
    "start:standalone": "mkdir -p .next/standalone/.next && cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public && INTERNAL_API_URL=\"http://localhost:3000\" SESSION_COOKIE_NAME=\"next-auth.session-token\" node .next/standalone/server.js",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --ignore-pattern .next --ignore-pattern coverage",
    "lint:staged": "lint-staged",
    "knip": "knip",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:report": "vitest run --coverage.enabled true --coverage.reporter=html && node ./scripts/openCoverageReport.mjs",
    "typecheck": "tsc --noEmit"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1012.0",
    "@aws-sdk/s3-request-presigner": "^3.1041.0",
    "@dnd-kit/core": "^6.3.1",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "5.22.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-virtual": "^3.13.24",
    "@types/papaparse": "^5.5.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "10.4.27",
    "boring-avatars": "^2.0.1",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "diff": "^8.0.4",
    "embla-carousel-react": "^8.6.0",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "exifr": "^7.1.3",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "next": "^16.2.4",
    "next-auth": "^4.24.7",
    "next-themes": "^0.2.1",
    "nodemailer": "^7.0.13",
    "papaparse": "^5.5.3",
    "postcss": "^8.5.9",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-day-picker": "^9.13.2",
    "react-dom": "^19.2.5",
    "react-easy-crop": "^5.5.6",
    "react-is": "^19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.0.0",
    "sanitize-html": "^2.17.3",
    "sass": "^1.98.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "3.3.3",
    "tailwindcss-animate": "^1.0.7",
    "unified": "^11.0.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.6",
    "@tailwindcss/typography": "^0.5.10",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^7.0.5",
    "@types/sanitize-html": "^2.16.1",
    "@vitest/coverage-v8": "^4.1.5",
    "cross-env": "^10.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "knip": "^6.3.1",
    "lint-staged": "^15.2.10",
    "prettier": "^3.8.1",
    "prisma": "5.22.0",
    "ts-node": "^10.9.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,md,css,scss,yml,yaml}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "tar": "^7.5.7",
    "recharts": {
      "@types/react": "$@types/react",
      "@types/react-dom": "$@types/react-dom"
    }
  }
}
