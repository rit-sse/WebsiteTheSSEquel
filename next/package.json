{
  "name": "website-the-ssequel",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "^20.20.1 || ^22.0.0"
  },
  "scripts": {
    "preinstall": "node ./scripts/check-node-version.cjs",
    "dev": "cross-env INTERNAL_API_URL=\"http://localhost:3000\" SESSION_COOKIE_NAME=\"next-auth.session-token\" next dev",
    "build": "next build",
    "start": "next start",
    "migrate:deploy": "prisma migrate deploy",
    "start:standalone": "mkdir -p .next/standalone/.next && cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public && INTERNAL_API_URL=\"http://localhost:3000\" SESSION_COOKIE_NAME=\"next-auth.session-token\" node .next/standalone/server.js",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --ignore-pattern .next",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:report": "vitest run --coverage.enabled true --coverage.reporter=html && node ./scripts/openCoverageReport.mjs",
    "typecheck": "tsc --noEmit"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
