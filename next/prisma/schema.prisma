model Photo {
  id Int @id @default(autoincrement())

  originalKey String @unique @db.VarChar(500)
  galleryKey  String @unique @db.VarChar(500)

  originalFilename  String @db.VarChar(255)
  originalMimeType  String @db.VarChar(100)
  originalSizeBytes Int
  galleryMimeType   String @default("image/webp") @db.VarChar(100)
  gallerySizeBytes  Int

  caption     String?       @db.VarChar(500)
  altText     String?       @db.VarChar(500)
  // FK to PhotoCategory.slug, ON UPDATE CASCADE so officers can rename
  // a category in one click. ON DELETE RESTRICT prevents accidentally
  // dropping a category that still has photos — the dashboard surfaces
  // a "merge into …" picker instead.
  category    String        @default("general") @db.VarChar(80)
  categoryRef PhotoCategory @relation("PhotoCategoryRel", fields: [category], references: [slug], onUpdate: Cascade, onDelete: Restrict)

  eventId String?
  event   Event?  @relation(fields: [eventId], references: [id], onDelete: SetNull)

  uploadedById Int?
  uploadedBy   User? @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  exifTakenAt   DateTime?
  manualTakenAt DateTime?
  uploadedAt    DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sortDate DateTime
  status   String   @default("published") @db.VarChar(40)

  batchId String @db.VarChar(80)

  @@index([status, sortDate])
  @@index([status, sortDate, id])
  @@index([status, category, sortDate, id])
  @@index([status, eventId, sortDate, id])
  @@index([eventId])
  @@index([category])
  @@index([batchId])
}

model EventAttendance {
