  updatedAt                 DateTime                  @updatedAt

  presidentNomination ElectionNomination @relation(fields: [presidentNominationId], references: [id], onDelete: Cascade)
  invitee             User               @relation("RunningMateInvitee", fields: [inviteeUserId], references: [id], onDelete: Cascade)

  @@index([inviteeUserId, status])
