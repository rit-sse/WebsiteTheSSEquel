// ────────────────────────────────────────────────────────────────────
// Page builder
//
// A `Page` is an officer-editable site page. Content is a JSON document
// (`{ version: 1, blocks: BlockNode[] }`) shaped at the application
// layer by the Zod registry in `lib/pageBuilder/blocks.ts`. We chose
// JSON over a relational PageBlock table because every block type
// has a different prop shape — a relational schema would degrade into
// EAV. The trade-off: no FK from carousel blocks to PhotoCategory, so
// we walk the JSON at write time and validate semantically.
//
// Two content fields exist: `draftContent` is what officers edit and
// see in preview; `publishedContent` is what anonymous visitors see.
// On `publish` the draft is copied to published and a `PageVersion`
// snapshot is taken for rollback.
// ────────────────────────────────────────────────────────────────────
model Page {
  id   Int    @id @default(autoincrement())
  slug String @unique @db.VarChar(200) // e.g. "about" or "about/get-involved"

  title  String     @db.VarChar(200)
  status PageStatus @default(DRAFT)

  // System-locked pages render through the new pipeline but cannot be
  // edited from the dashboard. Used for content owned by other systems
  // (e.g. the constitution, which is sourced from governing-docs and
  // mutated through the amendment process).
  systemLocked Boolean @default(false)

  // Block JSON. See lib/pageBuilder/blocks.ts for the shape.
  draftContent     Json
  publishedContent Json?

  publishedAt   DateTime?
  publishedById Int?

  // SEO. Defaults are auto-generated from title + first text block on save.
  seoTitle       String? @db.VarChar(200)
  seoDescription String? @db.VarChar(500)

  // Navigation. `showInNav = true` makes the page appear under the
  // chosen `navSection` at `navOrder`. `navLabel` overrides `title`.
  showInNav  Boolean    @default(false)
  navSection NavSection @default(HIDDEN)
  navLabel   String?    @db.VarChar(80)
  navOrder   Int        @default(0)

  createdById Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  archivedAt   DateTime?
  archivedById Int?

  createdBy   User  @relation("PageCreatedBy", fields: [createdById], references: [id])
  publishedBy User? @relation("PagePublishedBy", fields: [publishedById], references: [id], onDelete: SetNull)
  archivedBy  User? @relation("PageArchivedBy", fields: [archivedById], references: [id], onDelete: SetNull)

  versions PageVersion[]

  @@index([status, slug])
  @@index([archivedAt])
  @@index([navSection, navOrder])
}

// Snapshot of `Page.publishedContent` taken on every publish.
// `contentHash` is sha256(JSON) so the publish route can short-circuit
// no-op publishes and the editor can show "draft is unchanged".
model PageVersion {
  id            Int      @id @default(autoincrement())
  pageId        Int
  version       Int // monotonically increasing per page; first publish = 1
  content       Json
  contentHash   String   @db.VarChar(64)
  publishedAt   DateTime @default(now())
  publishedById Int?

  page        Page  @relation(fields: [pageId], references: [id], onDelete: Cascade)
  publishedBy User? @relation(fields: [publishedById], references: [id], onDelete: SetNull)

  @@unique([pageId, version])
  @@index([pageId, publishedAt])
}

// Promoted from a free-string column on Photo to a managed table so
// officers can rename, add, and merge categories without code changes.
// `Photo.category` is now a foreign key to `PhotoCategory.slug` with
// ON UPDATE CASCADE — renaming a category propagates automatically.
// Built-ins (the original 6) cannot be deleted, only renamed.
model PhotoCategory {
  id          Int      @id @default(autoincrement())
  slug        String   @unique @db.VarChar(80)
  label       String   @db.VarChar(120)
  description String?  @db.VarChar(500)
  isBuiltIn   Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  photos Photo[] @relation("PhotoCategoryRel")
}

// Site navigation tree. Top-level groups have `parentId = null`. Each
// item links either to a Page (slug copied into href) or a custom URL.
// The hardcoded NavItem arrays in `components/nav/Navbar.tsx` are
// seeded into this table by the migration so Day-1 nav matches the
// existing site exactly.
model NavItem {
  id          Int     @id @default(autoincrement())
  parentId    Int?
  label       String  @db.VarChar(80)
  href        String  @db.VarChar(500)
  description String? @db.VarChar(500)
  sortOrder   Int     @default(0)
  isVisible   Boolean @default(true)
  alignment   String? @db.VarChar(10) // "start" | "end" — drives align="end" on the SE Office dropdown

  parent   NavItem?  @relation("NavItemChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children NavItem[] @relation("NavItemChildren")

  @@index([parentId, sortOrder])
}
