  // profile when they accept their running-mate invitation. Mirrors the
  // fields on `ElectionNomination` so the public election page and
  // ballot can render the VP with the same statement/program/eligibility
  // chips as a directly-nominated candidate.
  statement                 String                    @default("") @db.Text
  yearLevel                 Int?
  program                   String?                   @db.VarChar(100)
  canRemainEnrolledFullYear Boolean?
  canRemainEnrolledNextTerm Boolean?
  isOnCampus                Boolean?
  isOnCoop                  Boolean?
