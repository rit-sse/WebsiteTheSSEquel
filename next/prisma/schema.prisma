// Amendment 12: Vice President is chosen as a running mate by the
// President nominee after their nomination is accepted. One invitation per
// presidential nomination; the presidentNominationId unique constraint
// enforces that.
model ElectionRunningMateInvitation {
  id                        Int                       @id @default(autoincrement())
