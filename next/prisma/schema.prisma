// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AcademicTerm {
  SPRING
  SUMMER
  FALL
}

enum AlumniSource {
  manual
  from_user
}

enum AlumniCandidateStatus {
  pending
  approved
  rejected
}

enum AmendmentStatus {
  DRAFT
  OPEN
  PRIMARY_REVIEW
  VOTING
  APPROVED
  REJECTED
  MERGED
  WITHDRAWN
}

enum ElectionKind {
  PRIMARY_OFFICER
}

enum ElectionStatus {
  DRAFT
  NOMINATIONS_OPEN
  NOMINATIONS_CLOSED
  VOTING_OPEN
  VOTING_CLOSED
  CERTIFIED
  CANCELLED
  TIE_RUNOFF_REQUIRED
}

enum ElectionApprovalStage {
  CONFIG
  BALLOT
  CERTIFICATION
}

enum ElectionNominationStatus {
  PENDING_RESPONSE
  ACCEPTED
  DECLINED
  EXPIRED
  // Candidate accepted, then later pulled out — distinct from
  // DECLINED ("never said yes"). The IRV tally drops them the same
  // way as eliminated candidates: their preference rows just stop
  // counting, and ballots that ranked them flow to the next choice.
  WITHDRAWN
}

enum ElectionEligibilityStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ElectionEmailKind {
  NOMINATION_NOTICE
  BALLOT_ANNOUNCEMENT
  BALLOT_REMINDER
  RUNNING_MATE_INVITE
}

enum ElectionRunningMateStatus {
  INVITED
  ACCEPTED
  DECLINED
  EXPIRED
  WITHDRAWN
}

enum PositionCategory {
  PRIMARY_OFFICER
  COMMITTEE_HEAD
  SE_OFFICE
}

enum CommitteeHeadNominationCycleStatus {
  OPEN
  CLOSED
  ARCHIVED
}

enum CommitteeHeadApplicationSource {
  SELF
  NOMINATED
}

enum CommitteeHeadApplicationStatus {
  PENDING_ACCEPTANCE
  SUBMITTED
  SELECTED
  NOT_SELECTED
  DECLINED
  WITHDRAWN
}

enum CommitteeHeadThirdPartyNominationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

// Lifecycle of an officer-editable Page in the page-builder system.
// DRAFT     – exists but is not served publicly; visible in /dashboard/pages
//             and at /<slug>?preview=1 to officers.
// PUBLISHED – served to anonymous visitors via the [...slug] catch-all.
// ARCHIVED  – soft-deleted; the public route returns 410 Gone, but the row
//             is preserved so officers can restore it from the trash.
enum PageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// Where a Page surfaces in the site navigation when `showInNav = true`.
// HIDDEN means the page is reachable by URL only — no nav entry is generated.
enum NavSection {
  TOP_LEVEL
  STUDENTS
  ALUMNI
  COMPANIES
  SE_OFFICE
  HIDDEN
}

model User {
  //Store an automatically generated unique int for id
  id Int @id @default(autoincrement())

  //Store first and last name as Strings
  name String @db.VarChar(100)

  //Store email as a unique String
  email String @unique @db.VarChar(255)

  linkedIn                     String?       @db.VarChar(500)
  gitHub                       String?       @db.VarChar(500)
  description                  String?       @db.VarChar(1000)
  graduationTerm               AcademicTerm?
  graduationYear               Int?
  major                        String?       @db.VarChar(100)
  coopSummary                  String?       @db.VarChar(1000)
  profileCompletionGrantedTerm AcademicTerm?
  profileCompletionGrantedYear Int?

  //Image will be saved
  profileImageKey String? @db.VarChar(500)
  googleImageURL  String? @db.VarChar(500)

  emailVerified DateTime?

  // True for stub users created from the legacy database import. Cleared
  // when a real Google sign-in provides current profile details.
  isImported Boolean @default(false)

  // relational fields
  mentor               Mentor[]
  quotes               Quote[]
  officers             Officer[]
  account              Account[]
  session              Session[]
  projectContributions ProjectContributor[]
  projects             Project[]
  textbookCopies       TextbookCopies[]

  Memberships                 Memberships[]
  purchaseRequests            PurchaseRequest[]
  invitationsSent             Invitation[]
  eventAttendances            EventAttendance[]
  mentorApplications          MentorApplication[]
  techCommitteeApplications   TechCommitteeApplication[]
  mentorAvailability          MentorAvailability[]
  alumni                      Alumni?
  alumniCandidates            AlumniCandidate[]               @relation("AlumniCandidateOwner")
  reviewedAlumniCandidates    AlumniCandidate[]               @relation("AlumniCandidateReviewer")
  amendments                  Amendment[]
  amendmentVotes              AmendmentVote[]
  amendmentComments           AmendmentComment[]
  createdElections            Election[]                      @relation("ElectionCreator")
  certifiedElections          Election[]                      @relation("ElectionCertifier")
  electionApprovals           ElectionApproval[]
  electionNominationsMade     ElectionNomination[]            @relation("ElectionNominator")
  electionNominations         ElectionNomination[]            @relation("ElectionNominee")
  reviewedElectionNominations ElectionNomination[]            @relation("ElectionEligibilityReviewer")
  electionBallots             ElectionBallot[]
  electionEmailLogs           ElectionEmailLog[]
  runningMateInvitations      ElectionRunningMateInvitation[] @relation("RunningMateInvitee")
  uploadedPhotos              Photo[]
  committeeHeadApplications    CommitteeHeadApplication[]          @relation("CommitteeHeadApplicant")
  committeeHeadSelections      CommitteeHeadApplication[]          @relation("CommitteeHeadSelector")
  committeeHeadNominationsMade CommitteeHeadThirdPartyNomination[] @relation("CommitteeHeadNominator")
  committeeHeadNominations     CommitteeHeadThirdPartyNomination[] @relation("CommitteeHeadNominee")

  // Page builder relations
  pagesCreated          Page[]        @relation("PageCreatedBy")
  pagesPublished        Page[]        @relation("PagePublishedBy")
  pagesArchived         Page[]        @relation("PageArchivedBy")
  pageVersionsPublished PageVersion[]
}

model Alumni {
  //Store an automatically generated unique int for id
  id Int @id @default(autoincrement())

  //Store first and last name as Strings
  name String @db.VarChar(100)

  //Store email as a unique String
  email String @db.VarChar(255)

  linkedIn    String? @db.VarChar(500)
  gitHub      String? @db.VarChar(500)
  description String? @db.VarChar(1000)

  //Image will be saved
  image          String        @default("https://source.boringavatars.com/beam/") @db.VarChar(500)
  userId         Int?          @unique
  source         AlumniSource  @default(manual)
  graduationTerm AcademicTerm?
  graduationYear Int?

  //Store startDate and endDate as a String
  start_date String
  end_date   String

  //Store Quote and Previous Roles
  quote          String @default("") @db.VarChar(2000)
  previous_roles String @default("") @db.VarChar(1000)

  //Whether the alumni wants their email displayed publicly
  showEmail Boolean @default(false)

  //Whether the alumni wants to receive mass emails from officers
  receiveEmails Boolean @default(false)

  //Update requests referencing this alumni
  updateRequests AlumniRequest[]
  user           User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model AlumniCandidate {
  id     Int @id @default(autoincrement())
  userId Int

  name           String        @db.VarChar(100)
  email          String        @db.VarChar(255)
  linkedIn       String?       @db.VarChar(500)
  gitHub         String?       @db.VarChar(500)
  description    String?       @db.VarChar(1000)
  imageKey       String?       @db.VarChar(500)
  graduationTerm AcademicTerm?
  graduationYear Int?
  major          String?       @db.VarChar(100)
  coopSummary    String?       @db.VarChar(1000)

  status       AlumniCandidateStatus @default(pending)
  reviewedById Int?
  reviewedAt   DateTime?
  reviewNotes  String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  user       User  @relation("AlumniCandidateOwner", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("AlumniCandidateReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@unique([userId])
}

model AlumniRequest {
  //Store an automatically generated unique int for id
  id Int @id @default(autoincrement())

  //Store first and last name as Strings
  name String @db.VarChar(100)

  //Store email as a String
  email String @db.VarChar(255)

  linkedIn    String? @db.VarChar(500)
  gitHub      String? @db.VarChar(500)
  description String? @db.VarChar(1000)

  //Image will be saved
  image String @default("https://source.boringavatars.com/beam/") @db.VarChar(500)

  //Store startDate and endDate as a String
  start_date String
  end_date   String

  //Store Quote and Previous Roles
  quote          String @default("") @db.VarChar(2000)
  previous_roles String @default("") @db.VarChar(1000)

  //Whether the alumni wants their email displayed publicly
  showEmail Boolean @default(false)

  //Whether the alumni wants to receive mass emails from officers
  receiveEmails Boolean @default(false)

  //If set, this is an update request for an existing alumni record
  alumniId Int?
  alumni   Alumni? @relation(fields: [alumniId], references: [id], onDelete: Cascade)

  //Status of the request: pending, approved, rejected
  status String @default("pending")

  //Timestamp when request was created
  created_at DateTime @default(now())
}

model Quote {
  //Store an automatically generated unique int for id
  id Int @id @default(autoincrement())

  //Store the timestamp quote was added
  date_added DateTime

  //Store quote as a String
  quote String @db.VarChar(2000)

  //References userId of person who submitted the quote. Optional for legacy
  //quotes imported without a matching submitter.
  user_id Int?

  //Store author, person who said the qoute, as a String, default to anonymous
  author String @default("Anonymous") @db.VarChar(100)

  //Relational fields
  //Refrences user_id
  user User? @relation(fields: [user_id], references: [id])
}

model OfficerPosition {
  //Store an automatically generated unique int for id
  id Int @id @default(autoincrement())

  //Store position title as a String
  title String @unique

  //States primary as a boolean
  is_primary Boolean @default(false)

  //Store position alias email (e.g., sse-president@rit.edu)
  email String @unique

  category PositionCategory @default(PRIMARY_OFFICER)

  // Historical-only positions imported from old officer records. These
  // appear in history, but are hidden from current fillable positions.
  is_defunct Boolean @default(false)

  //Relational fields
  officers         Officer[]
  handoverDocument HandoverDocument?
  invitations      Invitation[]
  amendmentVotes   AmendmentVote[]
  electionOffices  ElectionOffice[]
  committeeHeadApplicationPreferences CommitteeHeadApplicationPreference[]
  selectedCommitteeHeadApplications   CommitteeHeadApplication[]
}

model HandoverDocument {
  //Store an automatically generated unique int for id
  id Int @id @default(autoincrement())

  //References positionId - one document per position
  positionId Int @unique

  //Store the markdown content
  content String @db.Text

  //Track when the document was last updated
  updatedAt DateTime @updatedAt

  //Relational field
  position OfficerPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)
}

model Officer {
  //Store an automatically generated unique int for id
  id Int @id @default(autoincrement())

  //Refrences positionId
  position_id Int

  //Refrences userId
  user_id Int

  //Store active status as a boolean
  is_active Boolean @default(true)

  //Store startDate and endDate as a DateTime
  start_date DateTime
  end_date   DateTime

  //Relational fields
  user     User            @relation(fields: [user_id], references: [id])
  position OfficerPosition @relation(fields: [position_id], references: [id])
}

model Mentor {
  //Store an automatically generated unique int for id
  id Int @id @default(autoincrement())

  //Refrences userId
  user_Id Int

  //Store expirationDate as a DateTime
  expirationDate DateTime

  //Stores active status as a Boolean
  isActive Boolean

  //Relatinal fields
  mentorSkill     MentorSkill[]
  courseTaken     CourseTaken[]
  schedule        Schedule[] // Legacy relation - to be deprecated
  scheduleBlocks  ScheduleBlock[] // New schedule system
  mentorHeadcount MentorHeadcountMentor[]
  menteeHeadcount MenteeHeadcountMentor[]
  user            User                    @relation(fields: [user_Id], references: [id])
}

model Skill {
  //Store an automatically generated unique int for id
  id Int @id @default(autoincrement())

  //Store skill as a unique String
  skill String @unique

  //Relational field
  mentorSkill MentorSkill[]
}

model MentorSkill {
  //Store an automatically generated unique int for id
  id Int @id @default(autoincrement())

  //Refrences mentorId
  mentor_Id Int

  //Refrences skillId
  skill_Id Int

  //Referential Fields
  mentor Mentor @relation(fields: [mentor_Id], references: [id])
  skill  Skill  @relation(fields: [skill_Id], references: [id])
}

model Department {
  //Store an automatically generated unique int for id
  id Int @id @default(autoincrement())

  //Store title as a String
  title String

  //Store short title as a String
  shortTitle String @default("GCIS")

  //Relatinal field
  course Course[]
}

model Course {
  //Store an automatically generated unique int for id
  id Int @id @default(autoincrement())

  //Store title as a String
  title String @db.VarChar(40)

  //Refrence departmentId
  departmentId Int

  //Stores code as an Integer
  code Int

  //Relational field
  courseTaken          CourseTaken[]
  menteeHeadcountLinks MenteeHeadcountCourse[]

  //Refrence field
  department Department @relation(fields: [departmentId], references: [id])
}

model CourseTaken {
  //Store an automatically generated unique int for id
  id       Int @id @default(autoincrement())
  mentorId Int // References Mentor.id
  courseId Int // References Course.id

  //Relation fields
  mentor Mentor @relation(fields: [mentorId], references: [id])
  course Course @relation(fields: [courseId], references: [id])
}

model HourBlock {
  //Store an automatically generated unique int for id
  id Int @id @default(autoincrement())

  //Stores day of the week as a String
  weekday String

  //Stores time block startTime as a DateTime
  startTime DateTime @db.Time()

  //Referenced relation field
  schedule Schedule[]
}

model Schedule {
  //Store an automatically generated unique int for id
  id Int @id @default(autoincrement())

  mentorId    Int // References Mentor.id
  hourBlockId Int // References HourBlock.id

  //Relational fields
  hourBlock HourBlock @relation(fields: [hourBlockId], references: [id])
  mentor    Mentor    @relation(fields: [mentorId], references: [id])
}

// New schedule system - cleaner approach from PR #254
model MentorSchedule {
  // Store an automatically generated unique int for id
  id Int @id @default(autoincrement())

  // Name of the schedule (e.g., "Fall 2026", "Spring 2026")
  name String

  // Whether this is the currently active schedule
  isActive Boolean @default(false)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relational fields
  blocks    ScheduleBlock[]
  semesters MentorSemester[]
}

// Semester-based mentor recruitment cycle
model MentorSemester {
  // Store an automatically generated unique int for id
  id Int @id @default(autoincrement())

  // Name of the semester (e.g., "Spring 2026", "Fall 2026")
  name String

  // When2Meet URL for availability collection
  when2meetUrl String?

  // Application window dates
  applicationOpen  DateTime?
  applicationClose DateTime?

  // Semester start/end dates (used for mentor offboarding)
  semesterStart DateTime?
  semesterEnd   DateTime?

  // Whether this is the currently active semester for applications
  isActive Boolean @default(false)

  // Link to the schedule for this semester
  scheduleId Int?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relational fields
  schedule        MentorSchedule?        @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  applications    MentorApplication[]
  availability    MentorAvailability[]
  mentorHeadcount MentorHeadcountEntry[]
  menteeHeadcount MenteeHeadcountEntry[]
}

// Mentor interest form submissions
model MentorApplication {
  // Store an automatically generated unique int for id
  id Int @id @default(autoincrement())

  // User who submitted the application (requires login)
  userId Int

  // Semester this application is for
  semesterId Int

  // Discord username
  discordUsername String

  // Pronouns (She/Her, He/Him, They/Them, Other)
  pronouns String

  // Major (SE, CS, Other with text)
  major String

  // Year level (1st, 2nd, 3rd, 4th, 5th, MS, Other)
  yearLevel String

  // Courses taken - stored as JSON array of course identifiers
  coursesJson String @db.Text

  // Other skills/technologies
  skillsText String @db.Text

  // Tools/technologies comfortable with
  toolsComfortable String @db.Text

  // Tools/technologies currently learning
  toolsLearning String @db.Text

  // Number of previous mentoring semesters (0-5+)
  previousSemesters Int @default(0)

  // Why interested in being a mentor
  whyMentor String @db.Text

  // Additional comments/questions
  comments String? @db.Text

  // Application status: pending, approved, rejected, invited
  status String @default("pending")

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relational fields
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  semester   MentorSemester @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  invitation Invitation?

  // Unique constraint: one application per user per semester
  @@unique([userId, semesterId])
}

enum Status {
  PENDING
  APPROVED
  REJECTED
  ASSIGNED
}

model TechCommitteeApplicationCycle {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isOpen    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applications TechCommitteeApplication[]
}

model TechCommitteeApplication {
  id Int @id @default(autoincrement())

  userId  Int
  cycleId Int

  yearLevel         String
  experienceText    String  @db.Text
  whyJoin           String  @db.Text
  weeklyCommitment  String
  preferredDivision String
  status            Status  @default(PENDING)
  finalDivision     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycle TechCommitteeApplicationCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@unique([userId, cycleId])
}

model CommitteeHeadNominationCycle {
  id        Int                                @id @default(autoincrement())
  name      String                             @db.VarChar(120)
  term      AcademicTerm
  year      Int
  status    CommitteeHeadNominationCycleStatus @default(OPEN)
  openedAt  DateTime                           @default(now())
  closedAt  DateTime?
  createdAt DateTime                           @default(now())
  updatedAt DateTime                           @updatedAt

  officerTermStart DateTime
  officerTermEnd   DateTime

  sourceElectionId Int?

  sourceElection Election?                  @relation(fields: [sourceElectionId], references: [id], onDelete: SetNull)
  applications   CommitteeHeadApplication[]
  nominations    CommitteeHeadThirdPartyNomination[]

  @@unique([term, year])
}

model CommitteeHeadApplication {
  id              Int                            @id @default(autoincrement())
  cycleId         Int
  applicantUserId Int
  source          CommitteeHeadApplicationSource
  status          CommitteeHeadApplicationStatus @default(SUBMITTED)

  yearLevel        String @default("") @db.VarChar(80)
  major            String @default("") @db.VarChar(120)
  experienceText   String @default("") @db.Text
  whyInterested    String @default("") @db.Text
  weeklyCommitment String @default("") @db.Text
  comments         String? @db.Text

  submittedAt        DateTime?
  acceptedAt         DateTime?
  declinedAt         DateTime?
  withdrawnAt        DateTime?
  selectedAt         DateTime?
  selectedById       Int?
  selectedPositionId Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cycle            CommitteeHeadNominationCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  applicant        User                         @relation("CommitteeHeadApplicant", fields: [applicantUserId], references: [id], onDelete: Cascade)
  selectedBy       User?                        @relation("CommitteeHeadSelector", fields: [selectedById], references: [id], onDelete: SetNull)
  selectedPosition OfficerPosition?             @relation(fields: [selectedPositionId], references: [id], onDelete: SetNull)
  preferences      CommitteeHeadApplicationPreference[]
  nominations      CommitteeHeadThirdPartyNomination[]

  @@unique([cycleId, applicantUserId])
}

model CommitteeHeadApplicationPreference {
  id                Int @id @default(autoincrement())
  applicationId     Int
  officerPositionId Int
  rank              Int

  application     CommitteeHeadApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  officerPosition OfficerPosition          @relation(fields: [officerPositionId], references: [id], onDelete: Cascade)

  @@unique([applicationId, officerPositionId])
  @@unique([applicationId, rank])
}

model CommitteeHeadThirdPartyNomination {
  id            Int @id @default(autoincrement())
  applicationId Int
  cycleId       Int
  nomineeUserId Int
  nominatorUserId Int

  reason                   String @db.Text
  suggestedPositionIdsJson String @db.Text
  status                   CommitteeHeadThirdPartyNominationStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  application CommitteeHeadApplication   @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  cycle       CommitteeHeadNominationCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  nominee     User                       @relation("CommitteeHeadNominee", fields: [nomineeUserId], references: [id], onDelete: Cascade)
  nominator   User                       @relation("CommitteeHeadNominator", fields: [nominatorUserId], references: [id], onDelete: Cascade)

  @@unique([cycleId, nomineeUserId, nominatorUserId])
}

// Mentor availability per user per semester (replaces When2Meet)
model MentorAvailability {
  // Store an automatically generated unique int for id
  id Int @id @default(autoincrement())

  // User who submitted availability
  userId Int

  // Semester this availability is for
  semesterId Int

  // Availability slots stored as JSON: [{weekday:1, hour:10}, {weekday:1, hour:11}, ...]
  slots String @db.Text

  // Timestamps
  updatedAt DateTime @updatedAt

  // Relational fields
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  semester MentorSemester @relation(fields: [semesterId], references: [id], onDelete: Cascade)

  // Unique constraint: one availability record per user per semester
  @@unique([userId, semesterId])
}

// 30-minute mentor headcount form entries
model MentorHeadcountEntry {
  id Int @id @default(autoincrement())

  semesterId Int?

  // Total people in the lab at the 30-minute mark
  peopleInLab Int

  // "How are you feeling?" response
  feeling String @db.Text

  // Timestamps
  createdAt DateTime @default(now())

  // Relational fields
  semester MentorSemester?         @relation(fields: [semesterId], references: [id], onDelete: SetNull)
  mentors  MentorHeadcountMentor[]
}

model MentorHeadcountMentor {
  id Int @id @default(autoincrement())

  entryId  Int
  mentorId Int

  entry  MentorHeadcountEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  mentor Mentor               @relation(fields: [mentorId], references: [id], onDelete: Cascade)

  @@unique([entryId, mentorId])
}

// 55-minute mentee headcount form entries
model MenteeHeadcountEntry {
  id Int @id @default(autoincrement())

  semesterId Int?

  // Count of distinct students mentored/mentoring
  studentsMentoredCount Int

  // Count of students who checked out tests
  testsCheckedOutCount Int

  // Free-text for "Other" class
  otherClassText String? @db.Text

  // Timestamps
  createdAt DateTime @default(now())

  // Relational fields
  semester MentorSemester?         @relation(fields: [semesterId], references: [id], onDelete: SetNull)
  mentors  MenteeHeadcountMentor[]
  classes  MenteeHeadcountCourse[]
}

model MenteeHeadcountMentor {
  id Int @id @default(autoincrement())

  entryId  Int
  mentorId Int

  entry  MenteeHeadcountEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  mentor Mentor               @relation(fields: [mentorId], references: [id], onDelete: Cascade)

  @@unique([entryId, mentorId])
}

model MenteeHeadcountCourse {
  id Int @id @default(autoincrement())

  entryId  Int
  courseId Int

  entry  MenteeHeadcountEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  course Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([entryId, courseId])
}

model ScheduleBlock {
  // Store an automatically generated unique int for id
  id Int @id @default(autoincrement())

  // Day of week: 1 = Monday, 5 = Friday
  weekday Int

  // Start hour in 24h time (10 = 10am, 17 = 5pm)
  startHour Int

  // Foreign keys
  mentorId   Int
  scheduleId Int

  // Relational fields
  mentor   Mentor         @relation(fields: [mentorId], references: [id])
  schedule MentorSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  // Unique constraint: one mentor per time slot per schedule
  @@unique([scheduleId, weekday, startHour, mentorId])
}

model GoLinks {
  //Store an automatically generated unique int for id
  id Int @id @default(autoincrement())

  //Store short link as a String
  golink String @db.VarChar(100)

  //Store url as a String
  url String @db.VarChar(500)

  //Description as a String
  description String? @db.VarChar(500)

  //createdAt stored as a DateTime default to the timestamp it was created at
  createdAt DateTime @default(now())

