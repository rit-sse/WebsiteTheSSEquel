model Memberships {
  id Int @id @default(autoincrement())

  // UserID referenced as foreign key
  userId Int

  reason    String
  dateGiven DateTime

  // Academic term this membership is granted for. Filled in by API
  // helpers from `lib/academicTerm.ts::getCurrentAcademicTerm()` when
  // not explicitly provided. Lets us archive-by-term instead of
  // wholesale-wiping on new-semester handover.
  //
  // Multiple rows per (userId, term, year) are intentional — historical
  // data showed members earning more than one membership in the same
  // term (multi-event swipes, officer-grant + earned, etc.). The earlier
  // unique constraint on this tuple was dropped after it silently
  // collapsed every legitimate duplicate to a single row.
  term AcademicTerm
