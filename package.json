{
  "name": "website-the-ssequel-workspace",
  "private": true,
  "packageManager": "pnpm@10.34.0",
  "engines": {
    "node": "^26.0.0"
  },
  "scripts": {
    "setup:dev": "git config core.hooksPath next/.husky && pnpm install --frozen-lockfile && docker compose -f docker-compose.dev.yml up -d && pnpm run prisma:migrate:deploy && pnpm run prisma:seed",
    "env:check": "pnpm --dir next run env:check",
    "dev": "pnpm --dir next run dev",
    "lint": "pnpm --dir next run lint",
    "lint:staged": "pnpm --dir next run lint:staged",
    "test": "pnpm --dir next run test",
    "typecheck": "pnpm --dir next run typecheck",
    "build": "pnpm --dir next run build",
    "knip": "pnpm --dir next run knip",
    "format:check": "pnpm --dir next exec prettier --config ../.prettierrc.json --ignore-path ../.prettierignore --check ..",
    "format:write": "pnpm --dir next exec prettier --config ../.prettierrc.json --ignore-path ../.prettierignore --write ..",
    "prisma:db:push": "pnpm --dir next exec prisma db push",
    "prisma:generate": "pnpm --dir next exec prisma generate",
    "prisma:migrate": "pnpm --dir next run prisma:migrate",
    "prisma:migrate:deploy": "pnpm --dir next run migrate:deploy",
    "prisma:seed": "pnpm --dir next run prisma:seed",
    "prisma:validate": "pnpm --dir next exec prisma validate",
    "check": "pnpm run lint && pnpm run test && pnpm run typecheck && pnpm run knip && pnpm run build",
    "test:report": "pnpm --dir next run test:report"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.14",
    "typescript": "^7.0.2"
  }
}
